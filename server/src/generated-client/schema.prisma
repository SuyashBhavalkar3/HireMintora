// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated-client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Organisation (HR / Employer Account)
// Supports two auth methods:
//   1. Manual  — email + hashed password
//   2. OAuth   — Supabase OAuth (Google, GitHub, etc.)
// An org may link both (e.g., signed up via OAuth,
// later added a password). The email is always the
// canonical unique identifier.
// ─────────────────────────────────────────────
model Organisation {
  id       String @id @default(uuid())
  fullName String
  email    String @unique

  // Manual auth — nullable so OAuth-only orgs skip it
  passwordHash String?

  // Supabase OAuth — nullable for manual-only orgs
  // supabaseUserId maps to auth.users.id in Supabase
  supabaseUserId String? @unique
  oauthProvider  String? // e.g. "google", "github"

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organisations")
}
