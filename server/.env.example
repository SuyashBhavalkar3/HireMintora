# ─── HireMintora Server — Environment Variables ──────────────────────────────
# Copy this file to `.env` and fill in the values below.
# NEVER commit the actual `.env` file to version control.

# ─── Application ─────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a long random hex string before production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Supported: "groq" (default), "openai", "gemini"
LLM_PROVIDER=groq
LLM_TEMPERATURE=0.5

# Groq (default provider)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (alternative — set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (alternative — set LLM_PROVIDER=gemini to use)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Sarvam AI (Speech-to-Text & Text-to-Speech) ─────────────────────────────
SARVAM_API_KEY=

# STT settings
SARVAM_STT_LANGUAGE_CODE=en-IN
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_STT_SAMPLE_RATE=16000
SARVAM_STT_INPUT_AUDIO_CODEC=pcm_s16le
SARVAM_STT_WS_URL=wss://api.sarvam.ai/speech-to-text/transcribe/ws
SARVAM_STT_HIGH_VAD_SENSITIVITY=true
SARVAM_STT_VAD_SIGNALS=true
SARVAM_STT_INCLUDE_API_KEY_IN_QUERY=false

# TTS settings
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE_CODE=en-IN
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_PACE=1.0
SARVAM_TTS_WS_URL=wss://api.sarvam.ai/text-to-speech/ws
SARVAM_TTS_OUTPUT_AUDIO_CODEC=mp3
SARVAM_TTS_OUTPUT_AUDIO_BITRATE=128k

# ─── Database (PostgreSQL via Supabase) ───────────────────────────────────────
# Pooled connection (for application queries via Prisma)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true

# Direct connection (for Prisma migrations only)
DIRECT_URL=postgresql://user:password@host:5432/postgres

# ─── CORS (Production only) ──────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave unset for dev ("*").
# Example: CORS_ORIGINS=https://app.hiremintora.com,https://interview.hiremintora.com
# CORS_ORIGINS=

# ─── Candidate App URL ───────────────────────────────────────────────────────
# Base URL for the interview client (used when generating invitation links).
CANDIDATE_APP_URL=http://localhost:3002